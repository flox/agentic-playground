#!/usr/bin/env bash
set -euo pipefail

# Wrapper for deepseek-tui to use ollama.
# deepseek-tui has native --provider ollama support.
#
# Usage: launch-deepseek --model <model> [deepseek args...]
#   e.g. launch-deepseek --model qwen2.5
#        launch-deepseek --model qwen2.5 --yolo

MODEL=""
DEEPSEEK_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      DEEPSEEK_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-deepseek --model <model> [deepseek args...]" >&2
  exit 1
fi

OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

exec deepseek \
  --provider ollama \
  --base-url "http://${OLLAMA_HOST}:${OLLAMA_PORT}" \
  --model "$MODEL" \
  ${DEEPSEEK_ARGS[@]+"${DEEPSEEK_ARGS[@]}"}
