#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gemini-cli to use omlx via llamacpp-proxy.
# gemini-cli speaks the Gemini API protocol; llamacpp-proxy translates
# Gemini API <-> OpenAI Chat Completions <-> omlx.
#
# NOTE: llamacpp-proxy is only available on aarch64-darwin (Apple Silicon).
#       Intel Mac users cannot use this wrapper.
#
# Usage: launch-gemini-omlx --model <hf-model-id> [gemini-cli args...]
#   e.g. launch-gemini-omlx --model mlx-community/Qwen3.5-9B-MLX-4bit

if [[ "$(uname -m)" != "arm64" ]]; then
  echo "Error: llamacpp-proxy is not available on Intel Mac (x86_64-darwin)." >&2
  echo "  gemini-cli via omlx requires Apple Silicon." >&2
  exit 1
fi

MODEL=""
GEMINI_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      GEMINI_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch gemini --model <hf-model-id> [gemini-cli args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "${BASH_SOURCE[0]%/*}/_omlx-ensure.sh"
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

PROXY_LISTEN="${LLAMACPP_PROXY_LISTEN:-127.0.0.1:8081}"
GEMINI_LISTEN="${LLAMACPP_PROXY_GEMINI_LISTEN:-127.0.0.1:8082}"

cleanup() {
  if [[ -n "${PROXY_PID:-}" ]]; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM HUP

PROXY_LOG="${FLOX_ENV_CACHE:-/tmp}/llamacpp-proxy-gemini.log"
llamacpp-proxy \
  --listen "$PROXY_LISTEN" \
  --backend "$OMLX_HOST:$OMLX_PORT" \
  --backend-api-key "$OMLX_API_KEY" \
  --backend-model "$MODEL" \
  --gemini-listen "$GEMINI_LISTEN" 2>>"$PROXY_LOG" &
PROXY_PID=$!

PROXY_READY=false
for _ in $(seq 1 30); do
  if ! kill -0 "$PROXY_PID" 2>/dev/null; then
    echo "Error: llamacpp-proxy failed to start (port ${PROXY_LISTEN} may be in use; see ${PROXY_LOG})" >&2
    exit 1
  fi
  if curl -sf --connect-timeout 1 --max-time 2 "http://${PROXY_LISTEN}/health" >/dev/null 2>&1; then
    PROXY_READY=true
    break
  fi
  sleep 0.1
done
if [[ "$PROXY_READY" != true ]]; then
  echo "Error: llamacpp-proxy did not become ready in time (see ${PROXY_LOG})" >&2
  exit 1
fi

export GEMINI_API_KEY="${GEMINI_API_KEY:-llamacpp-local}"
export GOOGLE_GEMINI_BASE_URL="http://${GEMINI_LISTEN}"

gemini -m "$MODEL" ${GEMINI_ARGS[@]+"${GEMINI_ARGS[@]}"}
