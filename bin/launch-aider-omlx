#!/usr/bin/env bash
set -euo pipefail

# Wrapper for aider to use omlx.
# aider uses OPENAI_API_BASE for custom OpenAI-compat endpoints; no proxy needed.
#
# Usage: launch-aider-omlx --model <hf-model-id> [aider args...]
#   e.g. launch-aider-omlx --model mlx-community/Qwen3.5-9B-MLX-4bit

MODEL=""
AIDER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      AIDER_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch aider --model <hf-model-id> [aider args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "${BASH_SOURCE[0]%/*}/_omlx-ensure.sh"
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

export OPENAI_API_BASE="http://${OMLX_HOST}:${OMLX_PORT}/v1"
export OPENAI_API_KEY="$OMLX_API_KEY"

exec aider \
  --model "openai/${MODEL}" \
  ${AIDER_ARGS[@]+"${AIDER_ARGS[@]}"}
