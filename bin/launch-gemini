#!/usr/bin/env bash
set -euo pipefail

# Wrapper for gemini-cli to use ollama via llamacpp-proxy.
# gemini-cli speaks the Gemini API protocol, so we need llamacpp-proxy
# to translate Gemini API <-> OpenAI Chat Completions <-> ollama.
#
# NOTE: gemini-cli still writes session/state data to ~/.gemini/.
# There is no --data-dir or equivalent to isolate this.
#
# Usage: launch-gemini --model <model> [gemini-cli args...]
#   e.g. launch-gemini --model qwen2.5
#        launch-gemini --model qwen2.5 -p "explain this codebase"

MODEL=""
GEMINI_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      GEMINI_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: launch-gemini --model <model> [gemini-cli args...]" >&2
  exit 1
fi

OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"

source "${BASH_SOURCE[0]%/*}/_ollama-ensure.sh"
ollama_ensure_model "$MODEL" "$OLLAMA_HOST" "$OLLAMA_PORT" || exit 1

PROXY_LISTEN="${LLAMACPP_PROXY_LISTEN:-127.0.0.1:8081}"
GEMINI_LISTEN="${LLAMACPP_PROXY_GEMINI_LISTEN:-127.0.0.1:8082}"

cleanup() {
  if [[ -n "${PROXY_PID:-}" ]]; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM HUP

PROXY_LOG="${FLOX_ENV_CACHE:-/tmp}/llamacpp-proxy-gemini.log"
llamacpp-proxy \
  --listen "$PROXY_LISTEN" \
  --backend "$OLLAMA_HOST:$OLLAMA_PORT" \
  --backend-model "$MODEL" \
  --gemini-listen "$GEMINI_LISTEN" 2>>"$PROXY_LOG" &
PROXY_PID=$!

PROXY_READY=false
for _ in $(seq 1 30); do
  if ! kill -0 "$PROXY_PID" 2>/dev/null; then
    echo "Error: llamacpp-proxy failed to start (port ${PROXY_LISTEN} may be in use; see ${PROXY_LOG})" >&2
    exit 1
  fi
  if curl -sf --connect-timeout 1 --max-time 2 "http://${PROXY_LISTEN}/health" >/dev/null 2>&1; then
    PROXY_READY=true
    break
  fi
  sleep 0.1
done
if [[ "$PROXY_READY" != true ]]; then
  echo "Error: llamacpp-proxy did not become ready in time (see ${PROXY_LOG})" >&2
  exit 1
fi

export GEMINI_API_KEY="${GEMINI_API_KEY:-llamacpp-local}"
export GOOGLE_GEMINI_BASE_URL="http://${GEMINI_LISTEN}"

gemini -m "$MODEL" ${GEMINI_ARGS[@]+"${GEMINI_ARGS[@]}"}
