#!/usr/bin/env bash
set -euo pipefail

# Wrapper for hermes-agent to use omlx.
# hermes-agent uses OpenAI-compat endpoints; no proxy needed.
#
# Usage: launch-hermes-omlx --model <hf-model-id> [hermes-agent args...]
#   e.g. launch-hermes-omlx --model mlx-community/Qwen3.5-9B-MLX-4bit

MODEL=""
HERMES_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)
      MODEL="${2:?--model requires a value}"
      shift 2
      ;;
    *)
      HERMES_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Usage: omlx launch hermes --model <hf-model-id> [hermes-agent args...]" >&2
  exit 1
fi

OMLX_HOST="${OMLX_HOST:-127.0.0.1}"
OMLX_PORT="${OMLX_PORT:-8000}"

source "${BASH_SOURCE[0]%/*}/_omlx-ensure.sh"
omlx_ensure_model "$MODEL" "$OMLX_HOST" "$OMLX_PORT" || exit 1

export OPENAI_BASE_URL="http://${OMLX_HOST}:${OMLX_PORT}/v1"
export OPENAI_API_KEY="$OMLX_API_KEY"

exec hermes-agent --model "$MODEL" ${HERMES_ARGS[@]+"${HERMES_ARGS[@]}"}
